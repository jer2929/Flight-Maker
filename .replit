run = "pip install -q -r requirements.txt && uvicorn app.main:app --host 0.0.0.0 --port $PORT"
entrypoint = "app/main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[deployment]
run = ["sh", "-c", "pip install -q -r requirements.txt && uvicorn app.main:app --host 0.0.0.0 --port $PORT"]

[[ports]]
localPort = 8000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "8000"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn app.main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000
